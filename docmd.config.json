    "appearance": "dark",
    "customCss": []
  },
  "navigation": [
    { "text": "Home", "url": "/" },
    { "text": "Getting started", "url": "/getting-started" },
    { "text": "Concepts", "url": "/concepts" },
    { "text": "Configuration", "url": "/configuration" },
    { "text": "Reference", "url": "/reference" }
  ],
  "plugins": {
    "search": {},
    "seo": { "titleTemplate": "%s | Laravel IAM AI" },
    "sitemap": { "url": "https://padosoft.github.io/laravel-iam-ai" },
    "git": { "repo": "https://github.com/padosoft/laravel-iam-ai", "branch": "main", "editLink": true, "lastUpdated": true }
  }
